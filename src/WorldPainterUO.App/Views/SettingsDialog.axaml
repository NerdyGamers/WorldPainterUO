<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WorldPainterUO.App.Views.SettingsDialog"
        Title="Settings"
        Width="540"
        Height="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#2d2d3f"
        Foreground="#ccc">

    <DockPanel Margin="20">

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="90"
                    Click="OnOk"
                    Background="#4a7c59"
                    Foreground="White"
                    CornerRadius="4" />
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="90"
                    Click="OnCancel"
                    Background="#555"
                    Foreground="White"
                    CornerRadius="4" />
        </StackPanel>

        <StackPanel Spacing="20">

            <!-- UO Data Path -->
            <StackPanel Spacing="6">
                <TextBlock Text="UO Data Path"
                           FontWeight="SemiBold"
                           Foreground="#ddd" />
                <TextBlock Text="The folder containing radarcol.mul, tiledata.mul, art.mul, etc."
                           FontSize="11"
                           Foreground="#888"
                           TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,8,Auto">
                    <TextBox x:Name="UoDataPathBox"
                             Grid.Column="0"
                             Watermark="e.g. C:\Program Files (x86)\Electronic Arts\Ultima Online"
                             Background="#1e1e30"
                             Foreground="#ccc"
                             BorderBrush="#555"
                             CornerRadius="4" />
                    <Button Grid.Column="2"
                            Content="Browse…"
                            Click="OnBrowse"
                            Background="#444"
                            Foreground="#ccc"
                            CornerRadius="4"
                            Padding="12,6" />
                </Grid>
                <TextBlock x:Name="PathStatusText"
                           FontSize="11"
                           TextWrapping="Wrap"
                           IsVisible="False" />
            </StackPanel>

            <!-- Theme -->
            <StackPanel Spacing="6">
                <TextBlock Text="Theme"
                           FontWeight="SemiBold"
                           Foreground="#ddd" />
                <ComboBox x:Name="ThemeBox"
                          Background="#1e1e30"
                          Foreground="#ccc"
                          BorderBrush="#555"
                          MinWidth="160">
                    <ComboBoxItem Content="Dark" />
                    <ComboBoxItem Content="Light" />
                </ComboBox>
            </StackPanel>

            <!-- New Map Defaults -->
            <StackPanel Spacing="6">
                <TextBlock Text="New Map Defaults"
                           FontWeight="SemiBold"
                           Foreground="#ddd" />
                <Grid ColumnDefinitions="120,*,16,120,*" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Default Width:"
                               Foreground="#aaa" VerticalAlignment="Center" />
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="DefaultWidthBox"
                               Background="#1e1e30" Foreground="#ccc" BorderBrush="#555" CornerRadius="4" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Default Height:"
                               Foreground="#aaa" VerticalAlignment="Center" />
                    <TextBox   Grid.Row="0" Grid.Column="4" x:Name="DefaultHeightBox"
                               Background="#1e1e30" Foreground="#ccc" BorderBrush="#555" CornerRadius="4" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Default Facet:"
                               Foreground="#aaa" VerticalAlignment="Center" Margin="0,8,0,0" />
                    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="DefaultFacetBox"
                               Background="#1e1e30" Foreground="#ccc" BorderBrush="#555" CornerRadius="4"
                               Margin="0,8,0,0" />
                </Grid>
            </StackPanel>

            <!-- Autosave -->
            <StackPanel Spacing="6" Orientation="Horizontal">
                <TextBlock Text="Autosave every"
                           Foreground="#aaa"
                           VerticalAlignment="Center" />
                <TextBox x:Name="AutosaveBox"
                         Width="60"
                         Background="#1e1e30"
                         Foreground="#ccc"
                         BorderBrush="#555"
                         CornerRadius="4" />
                <TextBlock Text="seconds (0 = disabled)"
                           Foreground="#888"
                           VerticalAlignment="Center" />
            </StackPanel>

        </StackPanel>
    </DockPanel>
</Window>
